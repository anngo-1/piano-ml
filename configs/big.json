{
  "seed": 21,
  "data_dir": "data",
  "processed_dir": "data/processed_maestro_remi",
  "models_dir": "models/remi-big",
  "output_dir": "outputs/remi-big",
  "maestro_url": "https://storage.googleapis.com/magentadata/datasets/maestro/v3.0.0/maestro-v3.0.0-midi.zip",
  "seq_len": 2048,
  "generation_len": 1024,
  "batch_size": 32,
  "epochs": 30,
  "learning_rate": 0.0001,
  "weight_decay": 0.01,
  "warmup_steps": 75,
  "grad_accum_steps": 1,
  "num_workers": 16,
  "mixed_precision": true,
  "label_smoothing": 0.01,
  "model": {
    "architecture": "modern",
    "d_model": 512,
    "num_heads": 8,
    "num_kv_heads": 2,
    "num_layers": 10,
    "ffn_dim": 2048,
    "dropout": 0.1,
    "rope_theta": 10000.0
  },
  "sampling": {
    "temperature": 1.02,
    "top_k": 58,
    "top_p": 0.92,
    "prompt": [
      0
    ],
    "repetition_penalty": 1.07,
    "constrained": true,
    "min_pitch": 21,
    "max_pitch": 108,
    "max_active_notes": 16
  },
  "optimizer": "muon",
  "muon_learning_rate": 0.006,
  "muon_momentum": 0.95,
  "tokenizer": "remi",
  "lr_schedule": "cosine",
  "min_lr_ratio": 0.2,
  "early_stopping_patience": 8,
  "resume_from": null
}
